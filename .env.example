# Copy this file to .env and replace placeholders with local values.
# AnalyseMe reads shell environment variables first, then a local .env file.

# Required: SonarQube/SonarCloud base URL. HTTPS is required unless explicitly allowed below.
SONARQUBE_URL="https://sonarcloud.io"

# Required: Sonar API token with read access to the target project.
# Do not commit real tokens.
SONARQUBE_TOKEN="replace-with-local-token"

# Usually required for SonarCloud.
SONARQUBE_ORGANIZATION="your-organization"

# Default project key when no tool projectKey is passed.
SONARQUBE_PROJECT_KEY="your-project-key"

# Optional analysis scope. Set only one of these values at a time.
# SONARQUBE_BRANCH="main"
# SONARQUBE_PULL_REQUEST="123"

# Development-only opt-in for trusted non-TLS Sonar URLs.
# SONARQUBE_ALLOW_INSECURE_HTTP="true"
